{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "sfdt chrome feature catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["features"],
  "properties": {
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "contexts", "enabledByDefault", "workspace", "sideButton", "bridgeRequired"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "not": { "const": "__open-workspace__" }
          },
          "name": { "type": "string", "minLength": 1 },
          "contexts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "enabledByDefault": { "type": "boolean" },
          "workspace": { "type": "boolean" },
          "sideButton": { "type": "boolean" },
          "bridgeRequired": { "type": "boolean" }
        }
      }
    }
  }
}
